# =========================
# 1. 前端环境 (Vue3 等)
# =========================
node_modules/
dist/
.npm/

# =========================
# 2. 后端与数据处理环境 (Flask & Python)
# =========================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/

# =========================
# 3. 大数据组件 (Spark)
# =========================
spark-warehouse/
metastore_db/
derby.log
.spark-staging/

# =========================
# 4. 数据库与敏感配置
# =========================
# 存放本地数据库账号密码的配置文件请务必忽略
.env
config.local.json
# 忽略本地生成的轻量级数据库文件（如适用）
*.sqlite3
*.db

# =========================
# 5. 本地大数据集与模型文件
# =========================
# 避免上传庞大的原始谣言数据集、模型文件或临时导出的结果
data/raw/
*.csv
*.json
*.model
*.parquet

# =========================
# 6. 操作系统与编辑器缓存 (Windows环境等)
# =========================
.vscode/
.idea/
Thumbs.db

*.log